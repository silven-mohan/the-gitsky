# Server
PORT=4000

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost:5173

# Session
SESSION_SECRET=replace-with-a-secure-random-secret

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Supabase — get these from your project's API settings
# For full backend access (bypasses RLS), use the service_role key instead of anon
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_service_role_key
